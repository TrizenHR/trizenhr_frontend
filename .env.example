# Server API URL (required). Local: http://localhost:5000/api — production: set at build time (e.g. CapRover).
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# App Environment
NEXT_PUBLIC_APP_ENV=development

# Full app URL for Open Graph / share links (e.g. https://trizenhr.com)
NEXT_PUBLIC_APP_URL=https://trizenhr.com

# Root domain for tenant URLs (e.g. trizenhr.com). Used by host helpers and login redirects.
NEXT_PUBLIC_APP_DOMAIN=trizenhr.com

# Tenant subdomain segment: use "org" for abc.org.trizenhr.com; leave empty for abc.trizenhr.com
NEXT_PUBLIC_TENANT_SUBDOMAIN=org
